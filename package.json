{
  "name": "wlmaz",
  "version": "1.0.0",
  "description": "Wiki Loves Monuments Azerbaijan Map",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite --host",
    "dev:backend": "tsx watch --env-file=.env src/index.ts",
    "update-data": "tsx scripts/update-monuments.ts && npm run convert-data",
    "convert-data": "json2geobuf < public/monuments.geojson > public/monuments.pbf",
    "build": "npm run convert-data && vue-tsc -b && vite build",
    "preview": "vite preview --host",
    "format": "prettier --write --list-different src/",
    "lint": "eslint src/ --ext .ts,.vue --fix",
    "analyze": "vite-bundle-visualizer",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,vue,js}": "eslint --fix"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-brands-svg-icons": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/vue-fontawesome": "3.2.0",
    "@unhead/vue": "3.1.8",
    "@vueuse/head": "2.0.0",
    "@wikimedia/codex": "2.5.1",
    "@wikimedia/codex-icons": "2.5.1",
    "chart.js": "4.5.1",
    "connect-redis": "9.0.0",
    "exifr": "7.1.3",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "express-session": "1.19.0",
    "fuse.js": "7.5.0",
    "geobuf": "4.0.0",
    "helmet": "8.2.0",
    "hpp": "0.2.3",
    "leaflet": "1.9.4",
    "leaflet-minimap": "3.6.1",
    "leaflet-sidebar-v2": "3.2.3",
    "leaflet.locatecontrol": "0.90.0",
    "leaflet.markercluster": "1.5.3",
    "morgan": "1.11.0",
    "multer": "2.1.1",
    "node-addon-api": "8.8.0",
    "node-gyp": "12.3.0",
    "oauth-1.0a": "2.2.6",
    "passport": "0.7.0",
    "passport-mediawiki-oauth": "0.1.0",
    "pbf": "5.1.2",
    "pinia": "3.0.4",
    "rate-limit-redis": "5.0.0",
    "redis": "6.0.0",
    "sharp": "0.34.5",
    "vue": "3.5.35",
    "vue-chartjs": "5.3.3",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@rushstack/eslint-patch": "1.16.1",
    "@tailwindcss/vite": "4.3.0",
    "@types/connect-redis": "0.0.23",
    "@types/express": "5.0.6",
    "@types/express-session": "1.19.0",
    "@types/geobuf": "3.0.4",
    "@types/geojson": "7946.0.16",
    "@types/hpp": "0.2.7",
    "@types/leaflet": "1.9.21",
    "@types/leaflet.markercluster": "1.5.6",
    "@types/morgan": "1.9.10",
    "@types/multer": "2.1.0",
    "@types/node": "24.12.4",
    "@types/passport": "1.0.17",
    "@types/pbf": "3.0.5",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vite-pwa/assets-generator": "1.0.2",
    "@vitejs/plugin-vue": "6.0.8",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "geojson": "0.5.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.1",
    "svgo": "4.0.1",
    "tailwindcss": "4.3.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vite-bundle-visualizer": "1.2.1",
    "vite-plugin-image-optimizer": "2.0.3",
    "vite-plugin-sitemap": "0.8.2",
    "vue-tsc": "3.3.3"
  },
  "overrides": {
    "passport": "0.7.0",
    "rollup-plugin-visualizer": {
      "rolldown": "npm:rolldown@latest"
    }
  }
}
